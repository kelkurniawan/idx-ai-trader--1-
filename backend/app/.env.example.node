# ────────────────────────────────────────────────────────────────────────────
# SahamGue Node.js News Microservice — Environment Variables
# Copy this file to .env and fill in all required values.
# Never commit .env to source control.
# ────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────
# Shared PostgreSQL with Python backend.
# IMPORTANT: Prisma requires PRISMA_DATABASE_URL if using a different var from Python.
DATABASE_URL=postgresql://postgres:password@localhost:5432/sahamgue

# ── Redis ──────────────────────────────────────────────────────────────────
# Used by BullMQ job queues for the news pipeline.
REDIS_URL=redis://localhost:6379

# ── AI APIs ───────────────────────────────────────────────────────────────
# Free tier — llama-3.3-70b-versatile (14,400 req/day)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# Paid — claude-3-5-sonnet (news classification + grounding)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Tavily search (optional — for agent web search)
# Get from: https://app.tavily.com
TAVILY_API_KEY=

# ── News Sources (RSS URLs, comma-separated) ──────────────────────────────
NEWS_SOURCES=https://www.kontan.co.id/rss/news,https://www.cnbcindonesia.com/rss,https://www.bisnis.com/rss,https://finance.detik.com/rss,https://www.idxchannel.com/rss

# ── Scheduler ─────────────────────────────────────────────────────────────
# Every 15 min, Mon–Fri, 08:45–16:15 WIB (01:45–09:15 UTC)
AGENT_CRON_SCHEDULE=*/15 1-9 * * 1-5

# ── Agent Settings ─────────────────────────────────────────────────────────
RELEVANCE_THRESHOLD=0.6
CLAUDE_BATCH_SIZE=5
DEDUP_TTL_SECONDS=1800

# ── App ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
