# ── AI APIs ───────────────────────────────────────────────────
GEMINI_API_KEY=""

# Free tier — llama-3.3-70b-versatile (14,400 req/day)
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Paid — claude-sonnet-4-5 (~$0.15-0.30/day at IDX news volume)
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# DeepSeek V3 — drop-in replacement for Claude (Free/Ultra-cheap)
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# AI Provider Routing (options: deepseek, claude)
AI_ENRICHMENT_PROVIDER="deepseek"

# ── News Sources (RSS URLs, comma-separated) ──────────────────
NEWS_SOURCES="https://www.kontan.co.id/rss/news,https://www.cnbcindonesia.com/rss,https://www.bisnis.com/rss,https://finance.detik.com/rss,https://www.idxchannel.com/rss"

# ── Scheduler ─────────────────────────────────────────────────
# Cron: every 15 min, Mon–Fri, 01:45–09:15 UTC (= 08:45–16:15 WIB)
AGENT_CRON_SCHEDULE="*/15 1-9 * * 1-5"

# ── Agent Settings ────────────────────────────────────────────
RELEVANCE_THRESHOLD="0.6"
CLAUDE_BATCH_SIZE="5"
DEDUP_TTL_SECONDS="1800"

# ── App ───────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

