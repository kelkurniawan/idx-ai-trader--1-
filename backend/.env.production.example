ENVIRONMENT=production
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/sahamgue

JWT_SECRET_KEY=replace_with_64_hex_chars
MFA_ENCRYPTION_KEY=replace_with_64_hex_chars

RECAPTCHA_SECRET_KEY=replace_with_live_secret
RECAPTCHA_SITE_KEY=replace_with_live_site_key
RECAPTCHA_ENABLED=true

OTP_STORE_BACKEND=redis
RATE_LIMIT_BACKEND=redis
REDIS_URL=redis://redis:6379/0

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=replace_me
SMTP_FROM=noreply@your-domain.com

GOOGLE_OAUTH_CLIENT_ID=replace_with_live_google_client_id
GEMINI_API_KEY=replace_with_live_gemini_key
# Clerk server-side auth configuration.
# Recommended launch auth methods in Clerk Dashboard:
# - Email address enabled
# - Password enabled
# - Email verification required
# - Authenticator app MFA enabled
# - Backup codes enabled
# - Disable unused phone/social/passwordless methods
CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
CLERK_JWKS_URL=

XENDIT_SECRET_KEY=replace_with_live_xendit_secret
XENDIT_WEBHOOK_TOKEN=replace_with_live_webhook_token
XENDIT_ENVIRONMENT=LIVE
XENDIT_SUCCESS_URL=https://your-domain.com/payment/success
XENDIT_FAILURE_URL=https://your-domain.com/payment/failed

OPS_ALERT_WEBHOOK_URL=https://your-alert-endpoint.example.com/webhook
OPS_ALERT_WEBHOOK_BEARER=

CORS_ORIGINS=https://your-domain.com
