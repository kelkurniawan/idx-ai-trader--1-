# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/sahamgue"

# ── Redis (Optional) ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── Auth (REQUIRED in Prod) ──────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="your-256-bit-secret"

# ── MFA Encryption (REQUIRED in Prod) ────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MFA_ENCRYPTION_KEY="your-256-bit-secret"

# ── AI configuration ─────────────────────────────────────────
# Required for Gemini proxy routes to function
GEMINI_API_KEY="AIzaSy..."

# ── App configuration ────────────────────────────────────────
ENVIRONMENT="development"
PORT=8000
