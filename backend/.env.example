# IDX AI Trader Backend - Environment Configuration
# Copy this file to .env and customize values for your environment.

# ===========================
# Core Settings
# ===========================

# Environment Mode: development | staging | production
# In development/staging, mock data is used and AI calls are disabled
ENVIRONMENT=development

# Gemini AI API Key (required for production, optional for dev)
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL
# Dev: SQLite (file-based, zero config)
# Prod: PostgreSQL recommended (e.g., postgresql://user:pass@host:5432/dbname)
DATABASE_URL=sqlite:///./idx_trader.db

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS Origins (comma separated)
# Add your frontend URL here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================
# Authentication & Security
# ===========================

# JWT Secret Key
# CRITICAL: Change this in production! Generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-secret-key-CHANGE-THIS-IN-PRODUCTION-12345
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REMEMBER_ME_EXPIRE_DAYS=30

# reCAPTCHA v2
# Dev: Google test keys below always pass — no registration needed
# Prod: Register at https://www.google.com/recaptcha/admin
#       Choose reCAPTCHA v2 → Invisible badge
#       Add your domain(s) and replace these keys
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
RECAPTCHA_ENABLED=true

# ===========================
# Email / SMTP (for OTP)
# ===========================
# Dev: Leave empty — OTPs will print to console
# Prod: Use SendGrid, Amazon SES, Mailgun, etc.
#
# SendGrid Example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=SG.your_sendgrid_api_key_here
#   SMTP_FROM=noreply@yourdomain.com
#
# Amazon SES Example:
#   SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
#   SMTP_PORT=587
#   SMTP_USER=your_ses_smtp_username
#   SMTP_PASSWORD=your_ses_smtp_password
#   SMTP_FROM=noreply@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@idxtrader.dev

# OTP settings
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6

# ===========================
# WhatsApp OTP (Meta Graph API)
# ===========================
# Dev: Leave empty — WhatsApp OTPs will print to console
# Prod: Register at https://developers.facebook.com
#       1. Create a Meta App → Add WhatsApp product
#       2. Get a WhatsApp Business phone number ID
#       3. Generate a permanent access token
#       4. Create an OTP message template in Meta Business Suite
#       5. Fill in the values below
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ===========================
# Google OAuth
# ===========================
# Dev: Leave empty — Google login uses mock mode (always accepts)
# Prod: 
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create an OAuth 2.0 Client ID (Web application)
#   3. Set Authorized JavaScript origins to your frontend URL
#   4. Set Authorized redirect URIs if using authorization code flow
#   5. Copy the Client ID here
GOOGLE_OAUTH_CLIENT_ID=

# ===========================
# File Uploads
# ===========================
# Dev: Stored locally in ./uploads/avatars/
# Prod: Consider cloud storage: AWS S3, Google Cloud Storage, Azure Blob
UPLOAD_DIR=./uploads/avatars
MAX_UPLOAD_SIZE_MB=5

# ===========================
# OTP Store Backend
# ===========================
# Dev: "memory" — Python dict, works for single server
# Prod: "redis" — distributed, supports multiple servers
OTP_STORE_BACKEND=memory
# Redis URL (only used when OTP_STORE_BACKEND=redis)
# REDIS_URL=redis://localhost:6379/0

# ===========================
# Future: Real IDX Data API
# ===========================
# IDX_API_KEY=your_idx_api_key
# IDX_API_BASE_URL=https://api.idx.co.id
